# OpenClaw Konfiguration fuer Hetzner
# Kopieren: cp .env.openclaw.example .env.openclaw
# Berechtigungen setzen: chmod 600 .env.openclaw

# --- OpenClaw Kern-Einstellungen ---
OPENCLAW_GATEWAY_PORT=3000
OPENCLAW_GATEWAY_TOKEN=dein-sicheres-token-hier   # openssl rand -hex 32

# --- LLM-Anbieter (mind. einen konfigurieren) ---
ANTHROPIC_API_KEY=sk-ant-...                       # https://console.anthropic.com/

# --- Messaging-Kanäle (optional) ---
# Telegram Bot (empfohlen fuer Benachrichtigungen)
# Bot erstellen: https://t.me/BotFather -> /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- KassenInfodienst-Integration ---
# Diese Variablen werden an digest.py weitergereicht
GMAIL_USER=deine@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
RECIPIENT_EMAIL=deine@gmail.com
LINKDAPI_KEY=
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=
