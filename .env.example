# OpenAI API Key – benötigt für Web-Suche und Analyse
# Besorgen unter: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optionale Modell-Overrides
# Standard: konkreter GPT-5.4-Snapshot aus den Projekt-Limits.
OPENAI_RESEARCH_MODEL=gpt-5.4-2026-03-05
OPENAI_SCORING_MODEL=gpt-5.4-2026-03-05
OPENAI_NEWSLETTER_MODEL=gpt-5.4-2026-03-05

# Gmail E-Mail-Versand (optional, nur für --email Flag)
# App-Passwort erstellen: https://myaccount.google.com/apppasswords
# (Voraussetzung: 2-Faktor-Authentifizierung muss aktiv sein)
GMAIL_USER=deine@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Empfänger (leer = gleiche Adresse wie GMAIL_USER)
RECIPIENT_EMAIL=deine@gmail.com

# ── LinkedIn-Integration (optional, eine der drei Optionen wählen) ──────────
#
# Option A: LinkdAPI (beste Qualität, 100 Free Credits, dann ~$20/Monat)
# Account erstellen: https://linkdapi.com
LINKDAPI_KEY=

# Option B: LinkedIn Voyager-API (kostenlos, nutzt deinen Browser-Session-Cookie)
# So bekommst du den li_at-Cookie:
#   1. Chrome öffnen → linkedin.com einloggen
#   2. F12 → Application → Cookies → linkedin.com → "li_at" kopieren
#   3. Lebensdauer ca. 1 Jahr – dann erneuern
LINKEDIN_LI_AT=

# Optional: JSESSIONID aus dem gleichen Cookie-Store (verbessert Stabilität)
# Gleicher Weg wie li_at – Cookie heißt "JSESSIONID"
LINKEDIN_JSESSIONID=

# Option C: Kein LinkedIn-Key → automatischer Google-RSS-Fallback (weniger Daten)
# Nichts eintragen – funktioniert ohne Key, aber liefert nur News-Links statt Posts
